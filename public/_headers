# Cloudflare Pages custom headers

# HTML pages — always revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1

# Next.js hashed static assets — immutable cache forever
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Legacy Vite assets (if any remain)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Videos — cache 30 days (these are large files)
/*.mp4
  Cache-Control: public, max-age=2592000

# Images in public — cache 30 days
/*.png
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000

# SEO & AEO static files — cache 1 hour
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

# Fonts — cache 1 year
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
