rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Site content & pages: public can READ, only authenticated admin can WRITE
    match /siteData/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Enquiries: anyone can CREATE (contact form), only admin can read/update/delete
    match /enquiries/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
